# ---------------------------------------------------------------------------
# Velvet Poker — environment template. Copy to `.env` and fill in.
# NEVER commit a real .env. Private keys must only ever live server-side.
# ---------------------------------------------------------------------------

# Postgres connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/velvet_poker?schema=public"

# Redis used for table state, locks, and pub/sub between web + ws processes.
REDIS_URL="redis://localhost:6379"

# Privy auth (https://dashboard.privy.io). The public app id is exposed to the client.
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_SECRET=""

# Solana RPC + network. Use devnet for development.
SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_NETWORK="devnet"

# Server-side hot wallet (base58 secret key) used to send withdrawals.
# SERVER ONLY. Never expose. In production use a KMS / signing service instead.
HOT_WALLET_PRIVATE_KEY=""

# Treasury address that aggregates user deposits.
TREASURY_WALLET_ADDRESS=""

# SPL mint for USDC. Mainnet default below; set a devnet/test mint for devnet.
USDC_MINT="EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"

# Custom SPL token (the house token). Public tables are token-only; private
# tables may use SOL, USDC, or this token. Leave empty to disable token play.
# TOKEN_MINT is server-only; decimals + symbol are NEXT_PUBLIC_ so the client
# can format and label token amounts.
TOKEN_MINT=""
NEXT_PUBLIC_TOKEN_DECIMALS=""
NEXT_PUBLIC_TOKEN_SYMBOL=""

# Admins by email (if a wallet has a linked email) and/or by Solana wallet
# address. Wallet-only logins typically have no email, so set ADMIN_WALLETS.
ADMIN_EMAILS="meesdontmiss@gmail.com"
ADMIN_WALLETS=""

# When true, the mock compliance provider auto-approves KYC/geo in DEV ONLY.
# MUST be false in production. Business logic never hard-codes approval.
ENABLE_DEV_COMPLIANCE_APPROVAL="true"

# Withdrawals at or above this lamport amount require manual admin review.
MIN_WITHDRAWAL_REVIEW_LAMPORTS="1000000000"

# Confirmations required before a deposit is credited to the internal ledger.
DEPOSIT_CONFIRMATIONS="32"

# Port for the standalone realtime poker WebSocket server (`npm run ws`).
WS_PORT="3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
